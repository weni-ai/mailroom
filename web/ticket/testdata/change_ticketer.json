[
    {
        "label": "error if ticketer not specified",
        "method": "POST",
        "path": "/mr/ticket/change_ticketer",
        "body": {
            "org_id": 1,
            "user_id": 3,
            "ticket_ids": [
                1,
                3
            ]
        },
        "status": 400,
        "response": {
            "error": "request failed validation: field 'ticketer_id' is required"
        }
    },
    {
        "label": "error if ticketer does not exist in org",
        "method": "POST",
        "path": "/mr/ticket/change_ticketer",
        "body": {
            "org_id": 1,
            "user_id": 3,
            "ticket_ids": [
                1,
                3
            ],
            "ticketer_id": 999999
        },
        "status": 400,
        "response": {
            "error": "no such ticketer: 999999"
        }
    },
    {
        "label": "changes the ticketer of the given tickets and preserves external_id when none is supplied",
        "method": "POST",
        "path": "/mr/ticket/change_ticketer",
        "body": {
            "org_id": 1,
            "user_id": 3,
            "ticket_ids": [
                1,
                3
            ],
            "ticketer_id": 3
        },
        "status": 200,
        "response": {
            "changed_ids": [
                1,
                3
            ]
        },
        "db_assertions": [
            {
                "query": "SELECT count(*) FROM tickets_ticket WHERE ticketer_id = 3 AND id IN (1, 3)",
                "count": 2
            },
            {
                "query": "SELECT count(*) FROM tickets_ticket WHERE id = 1 AND external_id = '17'",
                "count": 1
            },
            {
                "query": "SELECT count(*) FROM tickets_ticket WHERE id = 3 AND external_id = '34'",
                "count": 1
            }
        ]
    },
    {
        "label": "changes the ticketer and overwrites external_id with the supplied value",
        "method": "POST",
        "path": "/mr/ticket/change_ticketer",
        "body": {
            "org_id": 1,
            "user_id": 3,
            "ticket_ids": [
                1
            ],
            "ticketer_id": 1,
            "external_id": "room-from-new-ticketer"
        },
        "status": 200,
        "response": {
            "changed_ids": [
                1
            ]
        },
        "db_assertions": [
            {
                "query": "SELECT count(*) FROM tickets_ticket WHERE id = 1 AND ticketer_id = 1 AND external_id = 'room-from-new-ticketer'",
                "count": 1
            }
        ]
    },
    {
        "label": "clears external_id when an empty string is supplied",
        "method": "POST",
        "path": "/mr/ticket/change_ticketer",
        "body": {
            "org_id": 1,
            "user_id": 3,
            "ticket_ids": [
                3
            ],
            "ticketer_id": 1,
            "external_id": ""
        },
        "status": 200,
        "response": {
            "changed_ids": [
                3
            ]
        },
        "db_assertions": [
            {
                "query": "SELECT count(*) FROM tickets_ticket WHERE id = 3 AND ticketer_id = 1 AND external_id IS NULL",
                "count": 1
            }
        ]
    }
]
