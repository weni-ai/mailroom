[
    {
        "label": "error if ticketer not specified",
        "method": "POST",
        "path": "/mr/ticket/change_ticketer",
        "body": {
            "org_id": 1,
            "user_id": 3,
            "ticket_ids": [
                1,
                3
            ]
        },
        "status": 400,
        "response": {
            "error": "request failed validation: field 'ticketer_id' is required"
        }
    },
    {
        "label": "error if ticketer does not exist in org",
        "method": "POST",
        "path": "/mr/ticket/change_ticketer",
        "body": {
            "org_id": 1,
            "user_id": 3,
            "ticket_ids": [
                1,
                3
            ],
            "ticketer_id": 999999
        },
        "status": 400,
        "response": {
            "error": "no such ticketer: 999999"
        }
    },
    {
        "label": "changes the ticketer of the given tickets and clears external_id",
        "method": "POST",
        "path": "/mr/ticket/change_ticketer",
        "body": {
            "org_id": 1,
            "user_id": 3,
            "ticket_ids": [
                1,
                3
            ],
            "ticketer_id": 3
        },
        "status": 200,
        "response": {
            "changed_ids": [
                1,
                3
            ]
        },
        "db_assertions": [
            {
                "query": "SELECT count(*) FROM tickets_ticket WHERE ticketer_id = 3 AND id IN (1, 3)",
                "count": 2
            },
            {
                "query": "SELECT count(*) FROM tickets_ticket WHERE id IN (1, 3) AND external_id IS NOT NULL",
                "count": 0
            }
        ]
    }
]
